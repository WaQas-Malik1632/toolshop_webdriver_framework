<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite thread-count="5" name="Web UI Smoke Test Suite - Tool Shop">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="Web Smoke Tests" enabled="true">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="webTests.CustomerRegisterTest"/>
            <class name="webTests.LoginTest"/>
            <class name="webTests.HomePageTest"/>
            <class name="webTests.CustomerAccountTest"/>
            <class name="webTests.ContactTest"/>
        </classes>
    </test>

</suite>
