<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite thread-count="5" name="Web UI End-to-End Test Suit-Tool Shop Site">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <!-- Run full end-to-end tests -->
    <test name="Web E2E Tests" enabled="true">
        <groups>
            <run>
                <include name="e2e"/>
            </run>
        </groups>
        <classes>
            <class name="webTests.CustomerRegisterTest"/>
            <class name="webTests.LoginTest"/>
            <class name="webTests.HomePageTest"/>
            <class name="webTests.CustomerAccountTest"/>
            <class name="webTests.ContactTest"/>
        </classes>
    </test>

</suite> <!--End-to-End Test Suit-ToolShop Site-->
