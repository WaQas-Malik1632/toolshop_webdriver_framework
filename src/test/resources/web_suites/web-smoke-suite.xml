<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite thread-count="5" name="Web UI Smoke Test Suite" parallel="methods" verbose="1">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="webTests.listeners.TestListener"/>
    </listeners>

    <!-- Chrome Tests -->
    <test name="Chrome Tests">
        <parameter name="browser" value="chrome"/>
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="webTests.CustomerRegisterTest"/>
            <class name="webTests.LoginTest"/>
        </classes>
    </test>

    <!-- Edge Tests -->
    <test name="Edge Tests">
        <parameter name="browser" value="edge"/>
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="webTests.HomePageTest"/>
            <class name="webTests.CustomerAccountTest"/>
            <class name="webTests.ContactTest"/>
        </classes>
    </test>

</suite>
