<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite thread-count="10" name="Master Test Suite - Tool Shop">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="API Smoke Tests" enabled="true">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="apiTest.UserApiTest"/>
            <class name="apiTest.ProductApiTest"/>
            <class name="apiTest.BrandApiTest"/>
        </classes>
    </test>

    <test name="API E2E Tests" enabled="true">
        <groups>
            <run>
                <include name="e2e"/>
            </run>
        </groups>
        <classes>
            <class name="apiTest.UserApiTest"/>
            <class name="apiTest.ProductApiTest"/>
            <class name="apiTest.BrandApiTest"/>
        </classes>
    </test>

    <test name="Web Smoke Tests" enabled="true">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="testcases.CustomerRegisterTest"/>
            <class name="testcases.LoginTest"/>
            <class name="testcases.HomePageTest"/>
            <class name="testcases.CustomerAccountTest"/>
            <class name="testcases.ContactTest"/>
        </classes>
    </test>

    <test name="Web E2E Tests" enabled="true">
        <groups>
            <run>
                <include name="e2e"/>
            </run>
        </groups>
        <classes>
            <class name="testcases.CustomerRegisterTest"/>
            <class name="testcases.LoginTest"/>
            <class name="testcases.HomePageTest"/>
            <class name="testcases.CustomerAccountTest"/>
            <class name="testcases.ContactTest"/>
        </classes>
    </test>

</suite>
