<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Master Test Suite - Tool Shop" parallel="methods" thread-count="6" verbose="1">

    <!-- Global Listeners for All Tests -->
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="webTests.listeners.TestListener"/>
    </listeners>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!--                          API TESTS                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->

    <!-- API Smoke Tests -->
    <test name="API Smoke Tests" preserve-order="true">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="apiTests.CustomerRegisterApiTest"/>
            <class name="apiTests.UserLoginApiTest"/>
            <class name="apiTests.ProductApiTest"/>
            <class name="apiTests.BrandApiTest"/>
        </classes>
    </test>

    <!-- API E2E Tests -->
    <test name="API E2E Tests" preserve-order="true">
        <groups>
            <run>
                <include name="e2e"/>
            </run>
        </groups>
        <classes>
            <class name="apiTests.CustomerRegisterApiTest"/>
            <class name="apiTests.UserLoginApiTest"/>
            <class name="apiTests.ProductApiTest"/>
            <class name="apiTests.BrandApiTest"/>
        </classes>
    </test>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!--                       TDD WEB TESTS (TestNG)                            -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->

    <!-- TDD Web Smoke Tests - Chrome -->
    <test name="TDD Web Smoke Tests - Chrome" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="webTests.CustomerRegisterTest"/>
            <class name="webTests.LoginTest"/>
            <class name="webTests.HomePageTest"/>
            <class name="webTests.CustomerAccountTest"/>
            <class name="webTests.ContactTest"/>
        </classes>
    </test>

    <!-- TDD Web E2E Tests - Edge -->
    <test name="TDD Web E2E Tests - Edge" preserve-order="true">
        <parameter name="browser" value="edge"/>
        <groups>
            <run>
                <include name="e2e"/>
            </run>
        </groups>
        <classes>
            <class name="webTests.CustomerRegisterTest"/>
            <class name="webTests.LoginTest"/>
            <class name="webTests.HomePageTest"/>
            <class name="webTests.CustomerAccountTest"/>
            <class name="webTests.ContactTest"/>
        </classes>
    </test>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!--                       BDD TESTS (Cucumber)                              -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->

    <!-- BDD Smoke Tests -->
    <test name="BDD Smoke Tests" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="bdd.runners.SmokeTestRunner"/>
        </classes>
    </test>

    <!-- BDD Regression Tests -->
    <test name="BDD Regression Tests" preserve-order="true">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="bdd.runners.RegressionTestRunner"/>
        </classes>
    </test>

</suite>